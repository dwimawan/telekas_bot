# .env.local — Untuk development lokal (vercel dev)
# JANGAN commit file ini ke Git!
# Tambahkan ke .gitignore

# ── Telegram ──────────────────────────────────────────────────────────────────
# Token dari @BotFather
TELEGRAM_TOKEN=1234567890:AABBccDDeeFFggHH-IIjjKKllMMnnOOppQQ

# Chat ID kamu (cek via @userinfobot di Telegram)
# Bisa lebih dari satu, pisah dengan koma tanpa spasi
ALLOWED_CHAT_IDS=123456789

# ── Google Sheets ─────────────────────────────────────────────────────────────
# ID Spreadsheet dari URL: https://docs.google.com/spreadsheets/d/SPREADSHEET_ID/edit
SPREADSHEET_ID=1BxiMVs0XRA5nFMdKvBdBZjgmUUqptlbs74OgVE2upms

# Nama tab/sheet (default: Transaksi)
SHEET_NAME=Transaksi

# ── Google Service Account ────────────────────────────────────────────────────
# Paste seluruh isi file JSON service account sebagai satu baris
# Contoh: {"type":"service_account","project_id":"my-project",...}
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"...","private_key_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n","client_email":"bot-sheets@my-project.iam.gserviceaccount.com","client_id":"...","auth_uri":"https://accounts.google.com/o/oauth2/auth","token_uri":"https://oauth2.googleapis.com/token"}
